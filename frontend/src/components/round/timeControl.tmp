import {
  PauseCircleOutlined,
  PlayCircleOutlined,
  StopOutlined,
} from "@ant-design/icons";
import { Button, Row, Space, Typography } from "antd";
import { useEffect, useRef, useState } from "react";
import { Show } from "../show/show";
const { Title } = Typography;

export type TimerProps = {
  minutes: number;
  seconds: number;
  secondsLeft: number;
};

type Phase = "not_started" | "in_progress" | "paused" | "last_ten" | "end";

export const Timer = (props: TimerProps) => {
  const [prevPhase, setPrevPhase] = useState<Phase>("not_started");
  const [currentPhase, setCurrentPhase] = useState<Phase>("not_started");

  const bellRef = useRef<HTMLAudioElement | null>(null);
  const clapRef = useRef<HTMLAudioElement | null>(null);

  useEffect(() => {
    bellRef.current = new Audio("/sounds/bell.mp3");
    clapRef.current = new Audio("/sounds/clap.mp3");

    bellRef.current.volume = 1.0;
    clapRef.current.volume = 1.0;
  }, []);

  useEffect(() => {
    if (prevPhase === "not_started" && currentPhase === "in_progress") {
      bellRef.current?.play().catch(() => {});
    }
    if (prevPhase === "last_ten" && currentPhase === "end") {
      bellRef.current?.play().catch(() => {});
    }
    if (prevPhase === "in_progress" && currentPhase === "last_ten") {
      clapRef.current?.play().catch(() => {});
    }
  }, [currentPhase, prevPhase]);

  const isFinalCountdown = secondsLeft <= 10 && secondsLeft > 0;
  const flashOn = isFinalCountdown && secondsLeft % 2 === 0;
  if (isFinalCountdown && currentPhase === "in_progress") {
    setPrevPhase(currentPhase);
    setCurrentPhase("last_ten");
  }
  if (secondsLeft === 0 && currentPhase === "last_ten") {
    setPrevPhase(currentPhase);
    setCurrentPhase("end");
  }
  if (prevPhase === "last_ten" && currentPhase === "end") {
    setPrevPhase(currentPhase);
    props.onEnd();
  }

  return (
    <>
      <Row justify="center" style={{ margin: "12px 0 16px" }}>
        <Title
          level={1}
          style={{
            margin: 0,
            fontFamily: "monospace",
            fontWeight: flashOn ? 700 : 600,
            letterSpacing: 3,
            color: flashOn ? "#ff4d4f" : "inherit",
            transition: "color 0.3s ease, transform 0.3s ease",
            transform: flashOn ? "scale(1.05)" : "scale(1)",
          }}
        >
          {minutes}:{seconds}
        </Title>
      </Row>

      <Row justify="center">
        <Show show={props.showControls}>
          <Space size={12}>
            <Button
              type="primary"
              icon={isActive ? <PauseCircleOutlined /> : <PlayCircleOutlined />}
              onClick={() => {
                toggle();
                setPrevPhase(currentPhase);
                if (currentPhase === "not_started") {
                  props.onStart();
                  setCurrentPhase("in_progress");
                }
                if (currentPhase === "paused") {
                  setCurrentPhase("in_progress");
                }
                if (currentPhase === "in_progress") {
                  setCurrentPhase("paused");
                }
              }}
            >
              {isActive ? "Pause" : "Play"}
            </Button>

            <Button
              onClick={() => {
                reset();
                setCurrentPhase("not_started");
              }}
            >
              Reset
            </Button>

            <Button danger icon={<StopOutlined />} onClick={() => {}}>
              End
            </Button>
          </Space>
        </Show>
      </Row>
    </>
  );
};
